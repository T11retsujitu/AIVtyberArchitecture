# LLM プロバイダ：NVIDIA NIM（OpenAI 互換・docs/13）
# client（packages/core の nim-client）と nim-env.ts だけが参照する。ループ・ゲームは鍵を知らない。
NVIDIA_API_KEY=                                  # nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=                                        # demo で 1 本回すモデル id（例 qwen/qwen2.5-72b-instruct）
NIM_MODELS=                                        # bench で比較するモデル id をカンマ区切り
NIM_TEMPERATURE=0.8                                # キャラの揺らぎ（docs/00 §3-3）
NIM_STRUCTURED_OUTPUT=guided_json                 # guided_json | json_schema（docs/13 §3）

# demo の client 選択（mock=決定論の足場 / nim=本物）
DREAM_LLM=mock

# 旧：Anthropic を使う場合の鍵（現行の既定プロバイダは NIM・docs/13）
ANTHROPIC_API_KEY=

# Style-Bert-VITS2 など音声合成サーバ（voice/ で使用予定）
SBV2_BASE_URL=http://127.0.0.1:5000

# take実行
DREAM_SEED=
DREAM_TAKE_OUT_DIR=./takes
</content>
